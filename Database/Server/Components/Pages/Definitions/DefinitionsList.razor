@page "/definitions"
@using Allors.Database
@using Allors.Database.Domain
@using Allors.Services
@inject IDatabaseService DatabaseService

<PageTitle>Definitions</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Operations Definitions &amp; Work Masters</MudText>

@if (definitions == null)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadDefinitions" Class="mb-4">Refresh</MudButton>

    <MudText Typo="Typo.h5" GutterBottom="true">Operations Definitions</MudText>
    <MudTable Items="definitions" Hover="true" Striped="true" Elevation="2" Class="mb-6">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Type</MudTh>
            <MudTh>Version</MudTh>
            <MudTh>Description</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Name">@context.Name</MudTd>
            <MudTd DataLabel="Type">@context.OperationsType?.Name</MudTd>
            <MudTd DataLabel="Version">@context.Version</MudTd>
            <MudTd DataLabel="Description">@context.Description</MudTd>
        </RowTemplate>
    </MudTable>

    <MudText Typo="Typo.h5" GutterBottom="true">Work Masters</MudText>
    <MudTable Items="workMasters ?? Array.Empty<WorkMaster>()" Hover="true" Striped="true" Elevation="2">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Type</MudTh>
            <MudTh>Version</MudTh>
            <MudTh>Duration (min)</MudTh>
            <MudTh>Description</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Name">@context.Name</MudTd>
            <MudTd DataLabel="Type">@context.WorkType?.Name</MudTd>
            <MudTd DataLabel="Version">@context.Version</MudTd>
            <MudTd DataLabel="Duration (min)">@context.Duration</MudTd>
            <MudTd DataLabel="Description">@context.Description</MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private OperationsDefinition[]? definitions;
    private WorkMaster[]? workMasters;

    protected override void OnInitialized()
    {
        LoadDefinitions();
    }

    private void LoadDefinitions()
    {
        using var transaction = DatabaseService.Database.CreateTransaction();
        definitions = transaction.Extent<OperationsDefinition>().ToArray();
        workMasters = transaction.Extent<WorkMaster>().ToArray();
    }
}
