@page "/"

<PageTitle>ShopFloor</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">ShopFloor - ISA-95 Manufacturing Operations</MudText>
<MudText Typo="Typo.body1" Class="mb-6">Welcome to ShopFloor, a manufacturing execution system built on Allors3 and the ISA-95 (IEC 62264) standard.</MudText>

<MudGrid>
    <MudItem xs="12" md="4">
        <MudCard>
            <MudCardContent>
                <MudText Typo="Typo.h6">Equipment</MudText>
                <MudText Typo="Typo.body2">Manage your equipment hierarchy from Enterprise down to Work Units. Configure equipment properties and map physical assets.</MudText>
            </MudCardContent>
            <MudCardActions>
                <MudButton Variant="Variant.Text" Color="Color.Primary" Href="equipment">View Equipment</MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>
    <MudItem xs="12" md="4">
        <MudCard>
            <MudCardContent>
                <MudText Typo="Typo.h6">Maintenance</MudText>
                <MudText Typo="Typo.body2">Create and track maintenance job orders. Dispatch work, record completions, and track personnel and material actuals.</MudText>
            </MudCardContent>
            <MudCardActions>
                <MudButton Variant="Variant.Text" Color="Color.Primary" Href="maintenance">View Maintenance</MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>
    <MudItem xs="12" md="4">
        <MudCard>
            <MudCardContent>
                <MudText Typo="Typo.h6">Personnel</MudText>
                <MudText Typo="Typo.body2">Manage personnel classes (roles) and individual persons. Assign qualifications and track who is available for work.</MudText>
            </MudCardContent>
            <MudCardActions>
                <MudButton Variant="Variant.Text" Color="Color.Primary" Href="personnel">View Personnel</MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>
</MudGrid>
