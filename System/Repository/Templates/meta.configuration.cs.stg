define_interface(interface) ::= <<
    public partial class $interface.SingularName$ : Interface, Meta.$interface.SingularName$ {
        public $interface.SingularName$(MetaPopulation metaPopulation, System.Guid id, string tag = null) : base(metaPopulation, id, tag)
        {
        }

        Meta.M Meta.$interface.SingularName$.M => (Meta.M)this.M;

$interface.Subtypes:{subtype|$define_subtype(subtype)$}; separator="\n"$

$interface.DefinedProperties:{property|$define_propertyType(composite=interface, property=property)$}; separator="\n"$

$interface.InheritedProperties:{property|$define_inheritedpropertyType(composite=interface, property=property)$}; separator="\n"$

$interface.DefinedReverseProperties:{property|$define_reversepropertyType(composite=interface, property=property)$}; separator="\n"$

$interface.InheritedReverseProperties:{property|$define_inheritedreversepropertyType(composite=interface, property=property)$}; separator="\n"$

$interface.DefinedMethods:{method|$define_methodType(composite=interface, method=method)$}; separator="\n"$

$interface.InheritedMethods:{method|$define_methodType(composite=interface, method=method)$}; separator="\n"$
    }
>>

