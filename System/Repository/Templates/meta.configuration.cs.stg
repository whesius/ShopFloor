{
    public sealed partial class MetaPopulation : MetaPopulationBase, M {
$repository.Units:{unit|$m_unit(unit)$}; separator="\n"$
$repository.Interfaces:{interface|$m_interface(interface)$}; separator="\n"$
$repository.Classes:{class|$m_class(class)$}; separator="\n"$
    }
}
>>

m_unit(unit) ::= <<
        public $unit.SingularName$ $unit.SingularName$;
        Meta.$unit.SingularName$ M.$unit.SingularName$ => this.$unit.SingularName$;
>>

m_interface(interface) ::= <<
        public $interface.SingularName$ $interface.SingularName$;
        Meta.$interface.SingularName$ M.$interface.SingularName$ => this.$interface.SingularName$;
>>

m_class(class) ::= <<
        public $class.SingularName$ $class.SingularName$;
        Meta.$class.SingularName$ M.$class.SingularName$ => this.$class.SingularName$;
>>

